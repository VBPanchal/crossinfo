# Vite (baked in at build time — set before `npm run build` or Docker build)
VITE_SUPABASE_URL=https://YOUR_KONG_OR_API_HOST
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-jwt
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Public URL of this web app (QR codes, email links). Omit to use browser origin.
# Example: https://app.yourdomain.com
VITE_PUBLIC_APP_URL=
