# Copy to docker/.env and fill. Used by docker/docker-compose.yml for the **web** image build.

VITE_SUPABASE_URL=https://api.example.com
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
# Same origin users use in the browser (QR codes, redirects)
VITE_PUBLIC_APP_URL=https://app.example.com

WEB_PORT=8080
